DATABASE_URL=postgresql://user:password@localhost:5432/lineos
DATABASE_SSL=false
AUTH_SECRET=change-me
VITE_OPENWEATHER_API_KEY=

# Image uploads: local, imgbb, or s3
FILE_STORAGE_DRIVER=local
IMGBB_API_KEY=

# Required when FILE_STORAGE_DRIVER=s3
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=
S3_KEY_PREFIX=app-images
S3_FORCE_PATH_STYLE=false
S3_ACL=public-read
